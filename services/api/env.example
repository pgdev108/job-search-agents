# API Settings
API_TITLE=Job Search Agent API
API_VERSION=0.1.0
API_DESCRIPTION=API for Job Search Agent

# CORS Settings (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Server Settings
HOST=0.0.0.0
PORT=8000

# OpenAI (required for Phase 3: career page discovery)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Playwright (job count extraction)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAV_TIMEOUT_MS=30000

# Scrape behavior
SCRAPE_MAX_RETRIES=2
SCRAPE_DOMAIN_DELAY_MS=500

# Bulk scrape
BULK_SCRAPE_CONCURRENCY=4
BULK_SCRAPE_MAX_COMPANIES=6000
BULK_SCRAPE_UNIVERSE_DEFAULT=sp500
BULK_SCRAPE_REQUEST_TIMEOUT_SEC=3600

